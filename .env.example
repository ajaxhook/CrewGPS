# Ambiente
NODE_ENV=development
PORT=3000

# CORS (origens permitidas; separa por vírgulas)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# MongoDB
# Mantém o formato da tua string antiga, mas com placeholders:
# mongodb+srv://<UTILIZADOR>:<PASSWORD>@<CLUSTER>/<BASE>?retryWrites=true&w=majority&appName=<APPNAME>
MONGO_URI="mongodb+srv://<username>:<password>@apitaocomboio.gci4rfl.mongodb.net/crewgps?retryWrites=true&w=majority&appName=ApitaoComboio"
# (Opcional) Compatibilidade com código antigo que use MONGODB_URI:
# MONGODB_URI=${MONGO_URI}

# JWT
JWT_SECRET="<gera-um-segredo-muito-forte>"

# Email (ex.: Gmail SMTP com palavra-passe de aplicações)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="<o_teu_email@gmail.com>"
SMTP_PASS="<app_password_16_caracteres>"
EMAIL_FROM="CrewGPS <no-reply@teu-dominio.com>"

# HTTPS (opcional: se quiseres servir HTTPS diretamente no Node)
# HTTPS_KEY_PATH=certs/server.key
# HTTPS_CERT_PATH=certs/server.crt
